# SPY Credit Spread — environment template.
# Copy to config/.env (or project-root .env) and fill in.
# NEVER commit a filled-in copy.

# ── IBKR (TWS or Gateway) ──────────────────────────────────────────────────
# Paper port: 7497   |   Live port: 7496
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ── Alpaca paper (equity surrogate) ────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Journal / logs ─────────────────────────────────────────────────────────
JOURNAL_DB_PATH=data/trades.db
LOG_DIR=logs
LOG_LEVEL=INFO

# ── Risk defaults (can be overridden per-request) ──────────────────────────
MAX_CONCURRENT_POSITIONS=2
DAILY_LOSS_LIMIT_PCT=2.0
DEFAULT_STOP_LOSS_PCT=50.0
DEFAULT_TAKE_PROFIT_PCT=50.0
DEFAULT_TRAILING_STOP_PCT=0.0
FILL_TIMEOUT_SECONDS=30
MONITOR_INTERVAL_SECONDS=15
LIMIT_PRICE_HAIRCUT=0.05

# ── Event calendar (Tier-2) ────────────────────────────────────────────────
EVENT_CALENDAR_FILE=config/events_2026.json

# ── Optional webhook for EOD digest ────────────────────────────────────────
NOTIFY_WEBHOOK_URL=
