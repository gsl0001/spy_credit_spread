# Live-trading env template. Copy to .env.live and source before run-live.sh.
# Don't commit the actual .env.live — only this template.

# ── Risk circuit breakers ─────────────────────────────────────────────────
# All three fire as "risk_rejected" events in the journal and UI.

# Max concurrent open positions (across all brokers/strategies)
MAX_CONCURRENT_POSITIONS=2

# Daily loss cap as % of account equity. Bot stops opening new entries
# once realized loss today >= this %. Closed-position-only — see V13 note.
DAILY_LOSS_LIMIT_PCT=2.0

# Absolute $ daily loss cap. 0 = disabled. For small accounts, set this
# AS WELL AS the % cap — whichever trips first wins.
DAILY_LOSS_LIMIT_ABS=300

# Maximum entries per day (open + closed). Hard ceiling on bot activity
# in case strategy fires excessively. 0 = unlimited.
MAX_ORDERS_PER_DAY=5

# ── Safety flags — must remain unset/0 for live ───────────────────────────
# Event-blackout bypass. Setting to 1 disables CPI/FOMC/NFP filter. NEVER 1
# for live. The unit tests assume this is 0.
ALLOW_BYPASS_EVENT_BLACKOUT=0

# ── Notification ──────────────────────────────────────────────────────────
# Fill these in if you want Telegram alerts on every entry/exit/audit-fail.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
